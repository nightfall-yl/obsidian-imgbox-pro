{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "esModuleInterop": true,
    "target": "es2021",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "lib": ["dom", "es2021", "scripthost"]
  },
  "include": ["**/*.ts", "**/*.d.ts"],
}
